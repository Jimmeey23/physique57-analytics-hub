# Copy this file to `.env.local` (for Vercel) or export these in your environment
# These values are required by the serverless function at /api/payroll
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_SPREADSHEET_ID=
# Google OAuth Configuration - Set 1 (for some hooks)
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_1.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-REDACTED_SECRET_1
VITE_GOOGLE_REFRESH_TOKEN=REDACTED_REFRESH_TOKEN_1

# Google OAuth Configuration - Set 2 (for most hooks) - Comment this in if needed
# VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_2.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_SECRET=GOCSPX-REDACTED_SECRET_2
# VITE_GOOGLE_REFRESH_TOKEN=REDACTED_REFRESH_TOKEN_3

# Spreadsheet IDs  
VITE_EXPIRATIONS_SPREADSHEET_ID=1rGMDDvvTbZfNg1dueWtRN3LhOgGQOdLg3Fd7Sn1GCZo
VITE_SALES_SPREADSHEET_ID=12xbYJQrh5wyYDaFhQrq4L0-YkSSlA6z7nMCb66XEbCQ

# AI Summary Configuration
# OpenAI API Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration for persistent storage
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# AI Configuration
VITE_GEMINI_API_KEY=AIzaSy-REDACTED_GEMINI_KEY

# Environment
VITE_NODE_ENV=development

